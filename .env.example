# REQUIRED: Set a strong password for Lavalink authentication
LAVALINK_SERVER_PASSWORD=youshallnotpass

# Server port (Render overrides this automatically via PORT env var)
# SERVER_PORT=2333
# SERVER_ADDRESS=0.0.0.0

# --- Audio Sources ---
# LAVALINK_SERVER_SOURCES_YOUTUBE=true
# LAVALINK_SERVER_SOURCES_BANDCAMP=true
# LAVALINK_SERVER_SOURCES_SOUNDCLOUD=true
# LAVALINK_SERVER_SOURCES_TWITCH=true
# LAVALINK_SERVER_SOURCES_VIMEO=true
# LAVALINK_SERVER_SOURCES_NICO=true
# LAVALINK_SERVER_SOURCES_HTTP=true
# LAVALINK_SERVER_SOURCES_LOCAL=false

# --- Lavalink Server Settings ---
# LAVALINK_SERVER_BUFFERDURATIONMS=400
# LAVALINK_SERVER_FRAMEBUFFERDURATIONMS=5000
# LAVALINK_SERVER_OPUSENCODINGQUALITY=10
# LAVALINK_SERVER_RESAMPLINGQUALITY=LOW
# LAVALINK_SERVER_TRACKSTUCKTHRESHOLDMS=10000
# LAVALINK_SERVER_USESEEKGHOSTING=true
# LAVALINK_SERVER_YOUTUBEPLAYLISTLOADLIMIT=6
# LAVALINK_SERVER_PLAYERUPDATEINTERVAL=5
# LAVALINK_SERVER_GCWARNINGS=true
# LAVALINK_SERVER_YOUTUBESEARCHENABLED=true
# LAVALINK_SERVER_SOUNDCLOUDSEARCHENABLED=true
# LAVALINK_SERVER_SOUNDCLOUDFILTEROUTPREVIEWTRACKS=false
# LAVALINK_SERVER_NONALLOCATINGFRAMEBUFFER=false

# --- Timeouts ---
# LAVALINK_SERVER_TIMEOUTS_CONNECTTIMEOUTMS=3000
# LAVALINK_SERVER_TIMEOUTS_CONNECTIONREQUESTTIMEOUTMS=3000
# LAVALINK_SERVER_TIMEOUTS_SOCKETTIMEOUTMS=3000

# --- YouTube Config (for age-restricted videos) ---
# LAVALINK_SERVER_YOUTUBCONFIG_EMAIL=
# LAVALINK_SERVER_YOUTUBCONFIG_PASSWORD=

# --- HTTP Proxy ---
# LAVALINK_SERVER_HTTPCONFIG_PROXYHOST=
# LAVALINK_SERVER_HTTPCONFIG_PROXYPORT=3128
# LAVALINK_SERVER_HTTPCONFIG_PROXYUSER=
# LAVALINK_SERVER_HTTPCONFIG_PROXYPASSWORD=

# --- Rate Limiting ---
# LAVALINK_SERVER_RATELIMIT_IPBLOCKS=
# LAVALINK_SERVER_RATELIMIT_EXCLUDEDIPS=
# LAVALINK_SERVER_RATELIMIT_STRATEGY=RotateOnBan
# LAVALINK_SERVER_RATELIMIT_RETRYLIMIT=-1
# LAVALINK_SERVER_RATELIMIT_SEARCHTRIGGERSFAIL=true

# --- Metrics ---
# METRICS_PROMETHEUS_ENABLED=false
# METRICS_PROMETHEUS_ENDPOINT=/metrics

# --- Sentry (error tracking) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=

# --- Logging ---
# LOGGING_REQUEST_ENABLED=true
# LOGGING_REQUEST_INCLUDECLIENTINFO=true
# LOGGING_REQUEST_INCLUDEHEADERS=false
# LOGGING_REQUEST_INCLUDEQUERYSTRING=true
# LOGGING_REQUEST_INCLUDEPAYLOAD=true
# LOGGING_REQUEST_MAXPAYLOADLENGTH=10000
# LOGGING_REQUEST_BEFOREREQUEST=false

# --- JVM Options ---
# JAVA_TOOL_OPTIONS=-Xmx512m
